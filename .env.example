# .env.local (DO NOT COMMIT)

# Choose ONE provider: 'groq', 'openai', or 'google'
AI_PROVIDER=groq

# Groq (default — fast inference)
GROQ_API_KEY=
# GROQ_MODEL_ID=openai/gpt-oss-20b

# OpenAI (alternative)
# OPENAI_API_KEY=
# OPENAI_MODEL_ID=gpt-4-turbo

# Google (alternative)
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_MODEL_ID=gemini-1.5-pro-latest

# Voyage AI — embeddings + reranker
VOYAGE_API_KEY=

# Neon PostgreSQL (pgvector)
NEON_DATABASE_URL=

# RAG tuning
# RAG_MAX_CONTEXT_CHARS=8000

# Generation parameters
# AI_MAX_TOKENS=2048
# AI_TEMPERATURE=0.4
